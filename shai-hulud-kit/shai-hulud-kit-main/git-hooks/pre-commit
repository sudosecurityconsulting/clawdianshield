#!/usr/bin/env bash
# Pre-commit hook: Shai-Hulud / TeamPCP supply chain audit.
#
# Runs both:
#   1. Project-level: scripts/detect_compromise.py (if present)
#   2. Machine-level: ~/.shai-hulud/shai-hulud-audit.{sh,ps1} (if installed)
#
# Exits non-zero on alerts (commit blocked). Warnings are reported but don't block.
#
# To install: cp this file to .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# To skip in an emergency: git commit --no-verify (use sparingly)

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -z "$REPO_ROOT" ]]; then
    echo "pre-commit: not in a git repo, skipping audit" >&2
    exit 0
fi

YELLOW='\033[33m'
RED='\033[31m'
GREEN='\033[32m'
RESET='\033[0m'

FAILED=0

# --- Project-level scan ---
PROJECT_SCRIPT="$REPO_ROOT/scripts/detect_compromise.py"
if [[ -f "$PROJECT_SCRIPT" ]]; then
    echo "[pre-commit] running project audit..."
    if command -v python3 >/dev/null 2>&1; then
        PY=python3
    elif command -v python >/dev/null 2>&1; then
        PY=python
    else
        echo "${YELLOW}pre-commit: no python found, skipping project audit${RESET}" >&2
        PY=""
    fi

    if [[ -n "$PY" ]]; then
        $PY "$PROJECT_SCRIPT" --root "$REPO_ROOT"
        code=$?
        if [[ $code -ge 2 ]]; then
            echo -e "${RED}[pre-commit] project audit FAILED (alerts present)${RESET}" >&2
            FAILED=1
        elif [[ $code -eq 1 ]]; then
            echo -e "${YELLOW}[pre-commit] project audit has warnings (continuing)${RESET}" >&2
        fi
    fi
fi

# --- Machine-level scan ---
# Check for installed audit script. Use bash version on macOS/Linux, ps1 on Windows.
if [[ -f "$HOME/.shai-hulud/shai-hulud-audit.sh" ]]; then
    MACHINE_SCRIPT="$HOME/.shai-hulud/shai-hulud-audit.sh"
    echo "[pre-commit] running machine audit (quick mode)..."
    "$MACHINE_SCRIPT" --mode quick --quiet
    code=$?
    if [[ $code -ge 2 ]]; then
        echo -e "${RED}[pre-commit] machine audit FAILED (alerts present)${RESET}" >&2
        echo "Run '/pooptin quick' or '$MACHINE_SCRIPT --mode quick' for details." >&2
        FAILED=1
    elif [[ $code -eq 1 ]]; then
        echo -e "${YELLOW}[pre-commit] machine audit has warnings (continuing)${RESET}" >&2
    fi
elif command -v pwsh >/dev/null 2>&1 && [[ -f "$HOME/.shai-hulud/shai-hulud-audit.ps1" ]]; then
    echo "[pre-commit] running machine audit via pwsh..."
    pwsh -NoProfile -File "$HOME/.shai-hulud/shai-hulud-audit.ps1" -Mode quick -Quiet
    code=$?
    if [[ $code -ge 2 ]]; then
        echo -e "${RED}[pre-commit] machine audit FAILED (alerts present)${RESET}" >&2
        FAILED=1
    elif [[ $code -eq 1 ]]; then
        echo -e "${YELLOW}[pre-commit] machine audit has warnings (continuing)${RESET}" >&2
    fi
fi

if [[ $FAILED -ne 0 ]]; then
    echo "" >&2
    echo -e "${RED}Commit blocked by supply chain audit.${RESET}" >&2
    echo "  - Review the findings above" >&2
    echo "  - See docs/security/IOC_DETECTION_CHECKLIST.md if you have one" >&2
    echo "  - Use 'git commit --no-verify' to bypass (only if you've confirmed safe)" >&2
    exit 1
fi

echo -e "${GREEN}[pre-commit] supply chain audit clean${RESET}" >&2
exit 0
