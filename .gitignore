# Root .gitignore — repo-wide. Per-project rules live in clawdianshield/.gitignore

# Runner output — CLAUDE.md: never commit reports/
reports/

# Orchestration tooling — intentionally excluded from version control
# (see CLAUDE.md / PHASE3_STATUS.md)
mission-control
mission-control.md
orchestration/
clawdianshield/intelligence/gemini_bridge.py

# External tool checkouts (not submodules — no .gitmodules)
Roo-Code
Zoo-Code

# Downloaded external toolkits — large, regeneratable, not part of this project's source
PyRIT-main/
PyRIT-main.zip
ERAT-main/
antigravity-sdk-python-main/
antigravity-sdk-python-main.zip

# Atomic Red Team vendor checkout + generated scenario JSONs (218MB+, regenerate with atomic_converter.py)
ClawdianShield/vendor/
ClawdianShield/scenarios/atomic/

# One-off / throwaway patch scripts
fix_*.py

# Editor + extension binaries / large media
*.vsix
*.mp4

# Python
__pycache__/
*.pyc
.venv/

# OS / editor noise
.DS_Store
Thumbs.db

# archive/ — large binaries and sensitive reference files stay out of git
archive/*.zip
archive/*.tar.gz
archive/*.jpg
archive/*.png
archive/*.txt
archive/*.html
archive/SESSION_SUMMARY_*
# Allow archive/README.md
!archive/README.md
