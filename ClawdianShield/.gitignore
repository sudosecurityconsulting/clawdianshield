# Secrets — never commit real credentials
.env
.env.*
!.env.example

# Dependencies
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/

# Runner output — keep folder, ignore generated reports
reports/*.json

# Telemetry evidence + bind-mount state (regenerated per run)
evidence/*.jsonl
victim_state/
victim_logs/

# OS / editor noise
.DS_Store
Thumbs.db
*.log
*.pem
*.key
*.p12
*.pfx
