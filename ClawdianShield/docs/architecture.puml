@startuml ClawdianShield Architecture
!theme plain
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam backgroundColor #FAFAFA
skinparam component {
  BackgroundColor #E8F4FD
  BorderColor #2E86C1
  FontColor #1A1A1A
}
skinparam database {
  BackgroundColor #FEF9E7
  BorderColor #D4AC0D
}
skinparam cloud {
  BackgroundColor #EBF5FB
  BorderColor #1A5276
}
skinparam package {
  BackgroundColor #F4F6F7
  BorderColor #717D7E
}

title ClawdianShield — Full Simulator Architecture\n(as of April 2026)

' ─── External Services ────────────────────────────────────
cloud "Linear (linear.app)" as Linear {
  [Linear API] as LinearAPI
  [ClawdianShield Project] as LinearProject
  LinearAPI --> LinearProject
}

cloud "Claude API (Anthropic)" as ClaudeCloud {
  [Scenario Generator] as ClaudeGen
  note right of ClaudeGen : Phase 2 — generates\nscenario JSON from\nnatural language intent
}

' ─── Runtime Config ───────────────────────────────────────
package "Runtime Config (gitignored)" {
  database ".env" as Env {
    LINEAR_API_KEY
    ANTHROPIC_API_KEY
  }
}

' ─── Control Plane ────────────────────────────────────────
package "Control Plane" {
  [Scenario Loader] as Loader
  [Safety Gate] as Safety
  [Orchestrator] as Orch
  [Scheduler] as Sched

  Loader --> Safety : validate constraints
  Safety --> Orch : cleared scenario
  Orch --> Sched : ordered behavior plan
}

' ─── Execution Plane (Behaviors) ──────────────────────────
package "Execution Plane — behaviors/" {
  [FileTamperBehavior] as BFT
  [SyntheticAuthAnomalyBehavior] as BAA
  [RemoteArtifactBehavior] as BRA
  [StagingBehavior] as BST
  [PersistenceBehavior] as BPE
  [AntiForensicsBehavior] as BAF
  [CleanupBehavior] as BCL
}

Sched --> BFT
Sched --> BAA
Sched --> BRA
Sched --> BST
Sched --> BPE
Sched --> BAF
Sched --> BCL

' ─── Telemetry Plane ──────────────────────────────────────
package "Telemetry Plane — collectors/" {
  [EventBus] as EvBus
  [Normalizer] as Norm
  [FileEvents] as CE_F
  [ProcessEvents] as CE_P
  [AuthEvents] as CE_A
  [Correlation] as CE_C

  EvBus --> Norm
  Norm --> CE_F
  Norm --> CE_P
  Norm --> CE_A
  CE_F --> CE_C
  CE_A --> CE_C
}

BFT ..> EvBus : emit
BAA ..> EvBus : emit
BRA ..> EvBus : emit
BST ..> EvBus : emit
BPE ..> EvBus : emit
BAF ..> EvBus : emit

' ─── Evidence Store ───────────────────────────────────────
package "Evidence Store" {
  database "JSONL Events\nevidence/" as JSONL
  database "Run Reports\nreports/" as Reports
}

CE_C --> JSONL : normalized events
CE_F --> JSONL
CE_P --> JSONL
CE_A --> JSONL

' ─── Evaluation Plane ─────────────────────────────────────
package "Evaluation Plane — runner/" {
  [Scoring Engine] as Score
  [Report Generator] as ReportGen

  Score --> ReportGen
}

JSONL --> Score : observed events
ReportGen --> Reports : JSON scorecard

' ─── Scenario Library ─────────────────────────────────────
package "Scenario Library — scenarios/" {
  [fim_burst_tamper.json] as S1
  [synthetic_auth_abuse.json] as S2
  [remote_exec_artifacts.json] as S3
  [collection_staging.json] as S4
  [persistence_path_mutation.json] as S5
  [anti_forensics_pressure.json] as S6
  [full_storyline.json] as S7
  [+ 3 more] as S8
}

S1 --> Loader
S2 --> Loader
S3 --> Loader
S7 --> Loader

' ─── Docker Orchestration ────────────────────────────────
package "Docker — docker/" {
  [Dockerfile.runner] as DFR
  [docker-compose.yml] as DC
  DC --> DFR
}

DFR ..> Orch : containerised run

' ─── Project Management ──────────────────────────────────
[linear-bootstrap.js] as Bootstrap
Bootstrap ..> Env : reads LINEAR_API_KEY
Bootstrap --> LinearAPI : seeds backlog

ClaudeGen ..> Env : reads ANTHROPIC_API_KEY
ClaudeGen --> Loader : generated scenario JSON

@enduml


' ─── External ─────────────────────────────────────────────
cloud "Linear (linear.app)" as Linear {
  [Linear API] as LinearAPI
  [ClawdianShield Project] as LinearProject
  [Labels & Milestones] as Labels
  LinearAPI --> LinearProject
  LinearProject --> Labels
}

' ─── Runtime Config ───────────────────────────────────────
package "Runtime Config (gitignored)" {
  database ".env" as Env {
    LINEAR_API_KEY
  }
  database ".env.example" as EnvExample {
    LINEAR_API_KEY=<placeholder>
  }
}

' ─── ClawdianShield Repo ──────────────────────────────────
package "ClawdianShield" {

  package "scripts/" {
    [linear-bootstrap.js] as Bootstrap
  }

  package "collectors/" {
    [FIM Collector] as FIM
    [Process Collector] as Proc
    [Network Collector] as Net
  }

  package "detections/" {
    [Detection Rules] as Rules
    [Evidence Mapping] as EvidMap
  }

  package "scenarios/" {
    [Attack Scenarios] as Scenarios
  }

  package "victim/" {
    [Workstation Artifacts] as Artifacts
  }

  package "evidence/" {
    database "JSONL Events" as JSONLEvents
  }

  package "tests/" {
    [Test Harness] as Tests
  }

  package "docs/" {
    [architecture.puml] as ArchDiag
    [sequence-bootstrap.puml] as SeqDiag
  }
}

' ─── Relationships ────────────────────────────────────────
Bootstrap ..> Env : reads via dotenv
Bootstrap --> LinearAPI : @linear/sdk
LinearAPI --> LinearProject : create/sync issues

FIM --> JSONLEvents : emit JSONL
Proc --> JSONLEvents : emit JSONL
Net --> JSONLEvents : emit JSONL
JSONLEvents --> Rules : analysed by
Rules --> EvidMap : maps evidence

Scenarios --> Artifacts : seeds
Artifacts --> FIM : triggers events
Tests --> FIM : validates
Tests --> Proc : validates
Tests --> Net : validates

@enduml
