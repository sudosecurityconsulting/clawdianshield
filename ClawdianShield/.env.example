# Linear issue tracking (optional)
LINEAR_API_KEY=lin_api_<your_key_here>

# Gemini AI brief generation
GEMINI_API_KEY=your_gemini_api_key_here

# Splunk HEC forwarder (telemetry/forwarders/splunk_hec.py)
SPLUNK_HEC_URL=http://localhost:8088
SPLUNK_HEC_TOKEN=your_splunk_hec_token_here
SPLUNK_PASSWORD=YourSecurePassword123

# Elasticsearch shipper (telemetry/forwarders/elastic_shipper.py)
