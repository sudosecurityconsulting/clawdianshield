{
  "scenario_id": "lateral_movement_001",
  "name": "Lateral Movement Sim — SSH Key Theft, Hosts Discovery, Remote Exec Stubs",
  "class_name": "lateral_movement",
  "mode": "lab_only",
  "risk_level": "critical",
  "hosts": ["workstation-1"],
  "preconditions": ["telemetry collector active", "ssh keys seeded in /root/.ssh"],
  "behavior_profile": {
    "ssh_key_theft": true,
    "remote_staging": true,
    "cleanup": true
  },
  "custom_behaviors": {
    "ssh_key_theft": [
      {"step_id": "seed_ssh_artifacts", "command": "mkdir -p /root/.ssh /home/testuser/.ssh && echo 'ssh-rsa AAAAB3NzaC1 fake_key_material testkey@lab' > /root/.ssh/id_rsa.pub && echo 'Host lab-target\n  Hostname 10.0.0.100\n  User root\n  IdentityFile ~/.ssh/id_rsa' > /root/.ssh/config && chmod 600 /root/.ssh/config"},
      {"step_id": "enumerate_ssh_dirs", "command": "mkdir -p /tmp/ClawdianShield && find /root /home -name '*.pub' -o -name 'id_rsa' -o -name 'id_ed25519' -o -name 'authorized_keys' 2>/dev/null | head -20 > /tmp/ClawdianShield/ssh_keys_found.txt"},
      {"step_id": "read_known_hosts", "command": "cat /root/.ssh/known_hosts /home/*/.ssh/known_hosts 2>/dev/null | head -20 > /tmp/ClawdianShield/known_hosts_dump.txt || echo 'no known_hosts' > /tmp/ClawdianShield/known_hosts_dump.txt"},
      {"step_id": "copy_ssh_key", "command": "cp /root/.ssh/id_rsa.pub /tmp/ClawdianShield/exfil_key.pub 2>/dev/null || echo 'key copy failed (expected in lab)' > /tmp/ClawdianShield/exfil_key_status.txt"},
      {"step_id": "read_ssh_config", "command": "cat /root/.ssh/config 2>/dev/null > /tmp/ClawdianShield/ssh_config_dump.txt || echo 'no config' > /tmp/ClawdianShield/ssh_config_dump.txt"}
    ],
    "remote_staging": [
      {"step_id": "target_list_build", "command": "cat /tmp/ClawdianShield/known_hosts_dump.txt | awk '{print $1}' | sort -u | head -10 > /tmp/ClawdianShield/pivot_targets.txt 2>/dev/null || echo '10.0.0.100\n10.0.0.101' > /tmp/ClawdianShield/pivot_targets.txt"},
      {"step_id": "ssh_exec_stub", "command": "echo 'ssh -i /tmp/ClawdianShield/exfil_key.pub root@10.0.0.100 \"id && whoami && cat /etc/passwd\"' > /tmp/ClawdianShield/lateral_cmd.sh && chmod +x /tmp/ClawdianShield/lateral_cmd.sh"},
      {"step_id": "scp_stub", "command": "echo 'scp -i /tmp/ClawdianShield/exfil_key.pub /tmp/ClawdianShield/implant.sh root@10.0.0.100:/tmp/' >> /tmp/ClawdianShield/lateral_cmd.sh"},
      {"step_id": "persistence_via_authorized_keys_stub", "command": "echo 'cat /tmp/ClawdianShield/exfil_key.pub >> /root/.ssh/authorized_keys' > /tmp/ClawdianShield/auth_keys_inject.sh"},
      {"step_id": "collect_lateral_summary", "command": "wc -l /tmp/ClawdianShield/ssh_keys_found.txt /tmp/ClawdianShield/pivot_targets.txt > /tmp/ClawdianShield/lateral_summary.txt 2>/dev/null || true"}
    ]
  },
  "custom_behavior_techniques": {
    "ssh_key_theft": "T1552.004",
    "remote_staging": "T1570"
  },
  "custom_behavior_produces": {
    "ssh_key_theft": ["file_events", "process_events"],
    "remote_staging": ["file_events", "process_events"]
  },
  "expected_telemetry": {
    "file_events": true,
    "process_events": true
  },
  "detections_expected": [
    "ssh_key_read_detected",
    "known_hosts_accessed",
    "lateral_movement_script_written",
    "authorized_keys_modification_attempt"
  ],
  "success_criteria": [
    "id_rsa.pub / authorized_keys read generates file_events",
    "pivot_targets.txt written as staging artifact",
    "lateral_cmd.sh creation detected by file_observer"
  ],
  "safety_constraints": {
    "lab_environment_only": true,
    "no_real_ssh_connections": true,
    "no_real_exploit_logic": true,
    "no_unapproved_network_spread": true
  }
}
