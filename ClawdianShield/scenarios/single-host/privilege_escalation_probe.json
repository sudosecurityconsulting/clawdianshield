{
  "scenario_id": "privesc_probe_001",
  "name": "Privilege Escalation Probe — SUID Survey, Sudo Abuse, Capability Check",
  "class_name": "privilege_escalation",
  "mode": "lab_only",
  "risk_level": "high",
  "hosts": ["workstation-1"],
  "preconditions": ["telemetry collector active"],
  "behavior_profile": {
    "privesc_probe": true,
    "cleanup": true
  },
  "custom_behaviors": {
    "privesc_probe": [
      {"step_id": "suid_sweep", "command": "mkdir -p /tmp/ClawdianShield && find / -perm -4000 -type f 2>/dev/null | head -30 > /tmp/ClawdianShield/suid_bins.txt || true"},
      {"step_id": "sgid_sweep", "command": "find / -perm -2000 -type f 2>/dev/null | head -20 >> /tmp/ClawdianShield/suid_bins.txt || true"},
      {"step_id": "sudo_list", "command": "sudo -l 2>/dev/null > /tmp/ClawdianShield/sudo_perms.txt || echo 'sudo not available or restricted' > /tmp/ClawdianShield/sudo_perms.txt"},
      {"step_id": "sudoers_read", "command": "cat /etc/sudoers 2>/dev/null | grep -v '^#' > /tmp/ClawdianShield/sudoers_dump.txt || echo 'not readable' > /tmp/ClawdianShield/sudoers_dump.txt"},
      {"step_id": "capability_check", "command": "getcap -r / 2>/dev/null | head -20 > /tmp/ClawdianShield/capabilities.txt || echo 'getcap unavailable' > /tmp/ClawdianShield/capabilities.txt"},
      {"step_id": "writable_dirs", "command": "find /etc /usr/local/bin /var/www 2>/dev/null -writable -type f | head -20 > /tmp/ClawdianShield/writable_files.txt || true"},
      {"step_id": "cron_writable", "command": "ls -la /etc/cron.d/ /etc/cron.daily/ 2>/dev/null > /tmp/ClawdianShield/cron_perms.txt || true"},
      {"step_id": "privesc_summary", "command": "wc -l /tmp/ClawdianShield/suid_bins.txt /tmp/ClawdianShield/capabilities.txt > /tmp/ClawdianShield/privesc_summary.txt 2>/dev/null || true"}
    ]
  },
  "custom_behavior_techniques": {
    "privesc_probe": "T1548.001"
  },
  "custom_behavior_produces": {
    "privesc_probe": ["file_events", "process_events"]
  },
  "expected_telemetry": {
    "file_events": true,
    "process_events": true
  },
  "detections_expected": [
    "suid_enumeration_detected",
    "sudoers_file_read",
    "privilege_probe_artifact_written"
  ],
  "success_criteria": [
    "find -perm -4000 produces process_events",
    "/etc/sudoers read attempt logged",
    "suid_bins.txt written and detected by file_observer"
  ],
  "safety_constraints": {
    "lab_environment_only": true,
    "no_real_exploit_logic": true,
    "no_real_credential_attack_logic": true,
    "no_unapproved_network_spread": true
  }
}
