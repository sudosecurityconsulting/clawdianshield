{
  "scenario_id": "credential_hunting_001",
  "name": "Credential Hunting — Config & History Sweep",
  "class_name": "credential_access",
  "mode": "lab_only",
  "risk_level": "high",
  "hosts": ["workstation-1"],
  "preconditions": ["telemetry collector active", "victim filesystem seeded"],
  "behavior_profile": {
    "cred_hunt": true,
    "cleanup": true
  },
  "custom_behaviors": {
    "cred_hunt": [
      {"step_id": "seed_cred_artifacts", "command": "mkdir -p /tmp/ClawdianShield && echo 'DB_PASSWORD=sup3rS3cr3t' > /tmp/ClawdianShield/app.env && echo 'api_key=AKIAIOSFODNN7EXAMPLE' >> /tmp/ClawdianShield/app.env && echo 'token=ghp_FakeTokenForTesting12345' >> /tmp/ClawdianShield/config.conf"},
      {"step_id": "env_dump", "command": "env > /tmp/ClawdianShield/env_dump.txt"},
      {"step_id": "config_sweep", "command": "find /tmp/ClawdianShield -name '*.conf' -o -name '*.env' -o -name '*.cfg' 2>/dev/null > /tmp/ClawdianShield/config_hits.txt"},
      {"step_id": "keyword_grep", "command": "grep -rli 'password\\|passwd\\|secret\\|token\\|api_key\\|apikey' /tmp/ClawdianShield/ 2>/dev/null >> /tmp/ClawdianShield/config_hits.txt || true"},
      {"step_id": "history_probe", "command": "cat /root/.bash_history 2>/dev/null | head -50 > /tmp/ClawdianShield/history_sample.txt 2>/dev/null || echo 'no history' > /tmp/ClawdianShield/history_sample.txt"},
      {"step_id": "ssh_key_probe", "command": "find / -name 'id_rsa' -o -name 'id_ed25519' -o -name '*.pem' 2>/dev/null | head -20 > /tmp/ClawdianShield/key_hits.txt || true"}
    ]
  },
  "custom_behavior_techniques": {
    "cred_hunt": "T1552.001"
  },
